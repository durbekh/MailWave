# Django Settings
DJANGO_SECRET_KEY=your-very-long-and-secure-secret-key-change-this
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DB_NAME=mailwave
DB_USER=mailwave
DB_PASSWORD=mailwave_secret
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email Provider (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=MailWave

# SendGrid API (for advanced features)
SENDGRID_API_KEY=your-sendgrid-api-key

# AWS S3 (for media storage in production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=mailwave-media
AWS_S3_REGION_NAME=us-east-1

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Frontend
REACT_APP_API_URL=http://localhost/api
REACT_APP_WS_URL=ws://localhost/ws

# Tracking
TRACKING_DOMAIN=track.yourdomain.com
TRACKING_PIXEL_URL=http://localhost/api/analytics/track/open/
CLICK_TRACKING_URL=http://localhost/api/analytics/track/click/

# Rate Limiting
EMAIL_RATE_LIMIT_PER_SECOND=100
EMAIL_RATE_LIMIT_PER_DAY=100000

# Encryption
FIELD_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
